diff --git a/products/phone-controller/android/app/src/main/kotlin/com/productforge/phonecontroller/ui/ControllerPads.kt b/products/phone-controller/android/app/src/main/kotlin/com/productforge/phonecontroller/ui/ControllerPads.kt
